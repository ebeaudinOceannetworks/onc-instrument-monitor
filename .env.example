# Required — use ONC_TOKEN or ONC_API_TOKEN (notebooks use ONC_API_TOKEN)
ONC_TOKEN='65fd2427-c241-43b1-884b-c8a747e186d7'
# ONC_API_TOKEN=your_onc_token_here

# Database (optional — for junction-box status via sql/jb_status.sql)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Dashboard
DASHBOARD_TITLE=ONC Instrument Monitor
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5050
DASHBOARD_URL_PREFIX=
SCALAR_LOOKBACK_HOURS=24

# Performance: parallelism + disk cache (delete cache/ to force a cold rebuild)
MAX_WORKERS=8
CACHE_ENABLED=1
DISCOVERY_TTL=21600      # device discovery cache (seconds)
AVAILABILITY_TTL=3600    # archive-file listings cache (seconds)
SCALAR_TTL=1800          # scalar data cache (seconds)
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_TIME=07:00
AUTO_REFRESH_TIMEZONE=UTC

# Enabled data types (comma-separated): scalar_site, hydrophone, ...
# Comma-separated. Complex types (hydrophone, seismometer, adcp) are viewed
# per-instrument with data-availability widgets; scalar_site is viewed per-site.
ENABLED_DATA_TYPES=scalar_site,hydrophone

# JIRA (optional)
ENABLE_JIRA_INTEGRATION=false
JIRA_URL=https://jira.oceannetworks.ca
JIRA_PROJECT_KEYS=OPE,DATA,INSTR,DSO,DMAS
JIRA_PERSONAL_ACCESS_TOKEN=
JIRA_CLOUD=false
JIRA_SEARCH_DAYS_BACK=90
JIRA_MAX_RESULTS=20
