			els.dismissAll.hidden = count === 0;
		}
	}

	function _renderNotificationsEmptyState() {
		var els = _getNotificationsElements();
		if (!els.list) return;
		els.list.innerHTML = '';
		var empty = document.createElement('div');
		empty.className = 'notifications-empty-state';
		empty.innerHTML = '<strong>No active notifications</strong><p>All hydrophone issues have been reviewed or resolved.</p>';
		els.list.appendChild(empty);
		_setNotificationCount(0);
	}

	function _visibleNotificationCount() {
		var els = _getNotificationsElements();
		if (!els.list) return 0;
		return els.list.querySelectorAll('.new-issue-item').length;
	}

	function dismissIssue(locationCode, btn) {
		fetch(buildDashboardUrl('/api/dismiss'), {
			method: 'POST',
			headers: {'Content-Type': 'application/json'},
			body: JSON.stringify({locationCode: locationCode})
		}).then(function(resp) {
			if (resp.ok) {
				var item = btn.closest('.new-issue-item');
				if (item) item.remove();
				var count = _visibleNotificationCount();
				if (count === 0) {
					_renderNotificationsEmptyState();
				} else {
					_setNotificationCount(count);
				}
			}
		}).catch(function(e) { console.log('Dismiss failed (server may not be running):', e); });
	}

	function dismissAllIssues() {
		fetch(buildDashboardUrl('/api/dismiss-all'), {
			method: 'POST',
			headers: {'Content-Type': 'application/json'}
		}).then(function(resp) {
			if (resp.ok) {
				_renderNotificationsEmptyState();
			}
		}).catch(function(e) { console.log('Dismiss all failed:', e); });
	}

	function _renderNewIssues(issues) {
		var els = _getNotificationsElements();
		if (!els.list) return;
		if (!issues || issues.length === 0) {
			_renderNotificationsEmptyState();
			return;
		}

		var statusColors = { critical: '#dc3545', error: '#dc3545', warning: '#fd7e14', minor: '#ffc107' };
		var statusIcons = { critical: '✗', error: '⛔', warning: '⚠', minor: '⚠' };
		els.list.innerHTML = '';
		_setNotificationCount(issues.length);
		issues.forEach(function(issue) {
			var status = issue.status || 'unknown';
			var item = document.createElement('div');
			item.className = 'new-issue-item';
			item.id = 'issue-' + String(issue.locationCode || '').replace(/\./g, '-');
			item.style.borderLeft = '4px solid ' + (statusColors[status] || '#6c757d');

			var severity = document.createElement('div');
			severity.className = 'issue-severity';
			severity.style.backgroundColor = (statusColors[status] || '#6c757d');
			severity.textContent = (statusIcons[status] || '?') + ' ' + String(status).toUpperCase();
			item.appendChild(severity);

			var details = document.createElement('div');
			details.className = 'issue-details';
			var link = document.createElement('button');
			link.type = 'button';
			link.className = 'issue-location-link';
			link.textContent = issue.locationCode || 'Unknown';
			link.setAttribute('data-open-detail-location', issue.locationCode || '');
			details.appendChild(link);

			var message = document.createElement('span');
			message.className = 'issue-message';
			message.textContent = issue.message || '';
			details.appendChild(message);

			var since = document.createElement('span');
			since.className = 'issue-since';
			var firstSeen = issue.first_seen || '';
			if (firstSeen) firstSeen = firstSeen.slice(0, 16).replace('T', ' ');
			since.textContent = 'Since: ' + (firstSeen || 'Unknown');
			details.appendChild(since);

			item.appendChild(details);

			var dismiss = document.createElement('button');
			dismiss.className = 'dismiss-btn';
			dismiss.title = 'Dismiss this alert';
			dismiss.textContent = '✕';
			dismiss.onclick = function() { dismissIssue(issue.locationCode, dismiss); };
			item.appendChild(dismiss);

			els.list.appendChild(item);
		});
	}

	function refreshNewIssues() {
