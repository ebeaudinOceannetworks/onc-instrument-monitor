			min-height: 0;
			overflow-y: auto;
			padding-right: 4px;
		}
		.settings-scroll-area::-webkit-scrollbar {
			width: 8px;
		}
		.settings-scroll-area::-webkit-scrollbar-thumb {
			background: #c7d3df;
			border-radius: 8px;
