			align-items: center;
			gap: 7px;
			padding: 7px 11px;
			border-radius: 999px;
			font-weight: 600;
			letter-spacing: 0.01em;
			white-space: nowrap;
		}
		.device-link-icon {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 16px;
			height: 16px;
			color: currentColor;
		}
		.device-link-icon svg {
			display: block;
			width: 16px;
			height: 16px;
			fill: none;
			stroke: currentColor;
			stroke-width: 1.9;
			stroke-linecap: round;
			stroke-linejoin: round;
		}
		html[data-theme="dark"] .public-section-links .device-link,
		html[data-theme="dark"] .internal-section-links .device-link {
			background: rgba(124, 199, 255, 0.1);
			border-color: rgba(124, 199, 255, 0.18);
			color: #9ed7ff;
		}
		html[data-theme="dark"] .public-section-links .device-link:hover,
		html[data-theme="dark"] .internal-section-links .device-link:hover {
			background: rgba(124, 199, 255, 0.17);
			border-color: rgba(124, 199, 255, 0.28);
		}
		.public-section-details,
		.internal-section-details {
			margin: 0;
			padding: 0;
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
			gap: 12px 18px;
		}
		.public-section-detail-item,
		.internal-section-detail-item {
			display: grid;
			gap: 4px;
			padding-top: 10px;
			border-top: 1px solid var(--theme-divider);
			min-width: 0;
		}
		.public-section-details dd,
		.internal-section-details dd {
			margin: 0;
			font-size: 15px;
			font-weight: 600;
			line-height: 1.35;
			color: var(--theme-text);
			word-break: break-word;
		}
		.internal-section-detail-item-wide {
			grid-column: span 2;
		}
		.internal-section-details .muted {
			color: var(--theme-text-muted);
		}
		@media (max-width: 720px) {
			.public-section-header,
			.internal-section-header {
				padding-left: 14px;
			}
			.public-section-header::after,
			.internal-section-header::after {
				left: 14px;
			}
			.public-section-title-row h2,
			.internal-section-title-row h2 {
				font-size: clamp(1.65rem, 8vw, 2.2rem);
			}
			.public-section-links,
			.internal-section-links {
				justify-content: flex-start;
				flex-basis: 100%;
				padding-top: 2px;
			}
			.public-section-details,
			.internal-section-details {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			.internal-section-detail-item-wide {
				grid-column: span 2;
			}
		}
		@media (max-width: 520px) {
			.public-section-details,
			.internal-section-details {
				grid-template-columns: 1fr;
			}
			.internal-section-detail-item-wide {
				grid-column: span 1;
			}
			.internal-section-name-divider {
				display: none;
			}
		}
		/* Fix anchor scrolling position */
		html { scroll-padding-top: 80px; }
		
		/* Summary box styles */
		.summary-box { background: #e9ecef; border: 2px solid #6c757d; border-radius: 8px; padding: 15px; margin-bottom: 20px; }
		.summary-counts { display: flex; gap: 15px; margin-top: 10px; }
