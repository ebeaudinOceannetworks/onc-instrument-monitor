	function _stopPublicRefreshPolling() {
		if (!publicRefreshPollTimer) return;
		clearInterval(publicRefreshPollTimer);
		publicRefreshPollTimer = null;
	}

	function _startPublicRefreshPolling(previousUpdatedAt) {
		var baselineUpdatedAt = previousUpdatedAt || '';

		function pollOnce() {
			fetch(buildDashboardUrl('/api/runtime-status'))
				.then(function(resp) { return resp.json(); })
				.then(function(data) {
					if (!data || data.status !== 'ok') return;
					_applyRuntimeStatus(data);
					var refresh = data.refresh || {};
					var baselineMs = _isoToMs(baselineUpdatedAt);
					var finishedMs = _isoToMs(refresh.last_finished_at || '');

					if (refresh.last_status === 'running') {
						_setManualRefreshState(true, refresh.progress_pct, refresh.progress_message);
						_renderPublicRefreshButton(data.public_refresh || null, refresh);
						_renderOperatorRefreshControls(refresh);
						_setRefreshProgressIndicator(_formatRefreshProgressSummary(refresh), true, false);
						return;
					}

					if (
						refresh.last_status === 'ok'
						&& !isNaN(finishedMs)
						&& (isNaN(baselineMs) || finishedMs > baselineMs)
					) {
						_setManualRefreshState(false, 0, '');
						_stopPublicRefreshPolling();
						_renderPublicRefreshButton(data.public_refresh || null, refresh);
						_renderOperatorRefreshControls(refresh);
						_setRefreshProgressIndicator('refresh complete. Reloading...', false, false);
						_setLastUpdatedIndicator(refresh.last_finished_at || new Date().toISOString(), false);
						setTimeout(function() { window.location.reload(); }, 700);
						return;
					}

					if (refresh.last_status === 'error' && refresh.last_error) {
						_setManualRefreshState(false, 0, '');
						_stopPublicRefreshPolling();
						_renderPublicRefreshButton(data.public_refresh || null, refresh);
						_renderOperatorRefreshControls(refresh);
						_setLastUpdatedIndicator(baselineUpdatedAt, false);
						_setRefreshProgressIndicator(refresh.last_error, false, true);
						_hideRefreshProgressIndicator(10000);
					}
				})
				.catch(function() {});
		}

		_stopPublicRefreshPolling();
		pollOnce();
		publicRefreshPollTimer = setInterval(pollOnce, 5000);
	}

	function requestPublicRefresh() {
		var btn = document.getElementById('public-refresh-btn');
		if (!btn || btn.disabled || manualRefreshInProgress || !isPublicDashboardPage()) return;

		var lastUpdatedEl = document.getElementById('last-updated-indicator');
		var previousUpdatedAt = lastUpdatedEl ? (lastUpdatedEl.getAttribute('data-updated-at') || '') : '';
		_setManualRefreshState(true, 0, 'Requesting refresh...');
		_renderPublicRefreshButton(null, null);
		_renderOperatorRefreshControls(null);
		_setLastUpdatedIndicator(previousUpdatedAt, true);
		_setRefreshProgressIndicator('requesting refresh...', true, false);

		function finishWithError(message, publicRefresh) {
			_setManualRefreshState(false, 0, '');
			_renderPublicRefreshButton(publicRefresh || null, null);
			_renderOperatorRefreshControls(null);
			_setLastUpdatedIndicator(previousUpdatedAt, false);
			_setRefreshProgressIndicator(message || 'refresh failed', false, true);
			_hideRefreshProgressIndicator(10000);
		}

		fetch(buildDashboardUrl('/api/refresh'), { method: 'POST' })
			.then(function(resp) {
				return resp.json()
					.then(function(data) {
						return { ok: resp.ok, status: resp.status, data: data || {} };
					})
					.catch(function() {
						return { ok: resp.ok, status: resp.status, data: {} };
					});
			})
			.then(function(result) {
				var data = result.data || {};
				if (result.ok) {
					_setManualRefreshState(true, 0, 'Refresh in progress...');
					_renderPublicRefreshButton(data.public_refresh || null, null);
					_setRefreshProgressIndicator('refresh in progress...', true, false);
					_startPublicRefreshPolling(previousUpdatedAt);
					return;
				}
				if (result.status === 409 && data.status === 'already_refreshing') {
					_setManualRefreshState(true, 0, 'Another refresh is already running...');
					_renderPublicRefreshButton(data.public_refresh || null, null);
					_setRefreshProgressIndicator('another refresh is already running...', true, false);
					_startPublicRefreshPolling(previousUpdatedAt);
					return;
				}
				if (result.status === 429 && data.status === 'rate_limited') {
					finishWithError(data.message || 'refresh is temporarily rate-limited', data.public_refresh);
					return;
				}
				finishWithError(data.message || 'refresh failed', data.public_refresh);
			})
			.catch(function(e) {
				finishWithError(e.message || 'refresh failed');
			});
	}

	{% if show_issue_management %}
	function refreshDashboard() {
			var btn = document.getElementById('refresh-action-btn');
			if (!btn || manualRefreshInProgress) return;
			var lastUpdatedEl = document.getElementById('last-updated-indicator');
			var previousUpdatedAt = lastUpdatedEl ? (lastUpdatedEl.getAttribute('data-updated-at') || '') : '';
			_setManualRefreshState(true, 0, 'Connecting...');
			closeActionsMenu();
			_renderOperatorRefreshControls(null);
			_setLastUpdatedIndicator(previousUpdatedAt, true);
			_setRefreshProgressIndicator('0% connecting...', true, false);
			var failed = false;

			function showRefreshError(message) {
				if (failed) return;
				failed = true;
				_setManualRefreshState(false, 0, '');
				_renderOperatorRefreshControls(null);
				_setLastUpdatedIndicator(previousUpdatedAt, false);
				_setRefreshProgressIndicator(message || 'refresh failed', false, true);
				_hideRefreshProgressIndicator(8000);
			}

			// Open SSE stream for progress updates
			var evtSource = new EventSource(buildDashboardUrl('/api/refresh/progress'));
			var sawProgress = false;
			evtSource.onmessage = function(event) {
				try {
					var d = JSON.parse(event.data);
					sawProgress = true;
					var pct = parseInt(d.pct, 10);
					if (isNaN(pct)) pct = 0;
					var msg = d.message || 'Refreshing...';
					_setManualRefreshState(true, pct, msg);
					_renderOperatorRefreshControls(null);
					_setRefreshProgressIndicator(pct + '% ' + msg, true, false);
					if (pct >= 100) {
						evtSource.close();
						_setManualRefreshState(false, 0, '');
						_renderOperatorRefreshControls(null);
						_setRefreshProgressIndicator('100% complete. Reloading...', false, false);
						_setLastUpdatedIndicator(new Date().toISOString(), false);
						refreshNewIssues();
						setTimeout(function() { window.location.reload(); }, 500);
					}
				} catch(e) {}
			};
			evtSource.onerror = function() {
				evtSource.close();
				if (!sawProgress && !failed) {
					_setRefreshProgressIndicator('waiting for refresh updates...', true, false);
				}
			};

			// Trigger refresh in parallel with SSE so updates are visible throughout the run
			fetch(buildDashboardUrl('/api/refresh'), { method: 'POST' })
				.then(function(resp) {
					return resp.json()
						.then(function(data) {
							return { ok: resp.ok, status: resp.status, data: data || {} };
						})
						.catch(function() {
							return { ok: resp.ok, status: resp.status, data: {} };
						});
				})
					.then(function(result) {
						if (result.ok) {
							if (!sawProgress) {
								_setManualRefreshState(false, 0, '');
								_renderOperatorRefreshControls(null);
								_setRefreshProgressIndicator('100% complete. Reloading...', false, false);
								_setLastUpdatedIndicator(new Date().toISOString(), false);
								refreshNewIssues();
								setTimeout(function() { window.location.reload(); }, 500);
								return;
							}
							setTimeout(function() {
								if (!manualRefreshInProgress) return;
								evtSource.close();
								_setManualRefreshState(false, 0, '');
								_renderOperatorRefreshControls(null);
								_setRefreshProgressIndicator('refresh complete. Reloading...', false, false);
								_setLastUpdatedIndicator(new Date().toISOString(), false);
								refreshNewIssues();
								window.location.reload();
							}, 1200);
							return;
						}
						if (result.status === 409 && result.data && result.data.status === 'already_refreshing') {
							_setManualRefreshState(false, 0, '');
							_renderOperatorRefreshControls(null);
							_setRefreshProgressIndicator('another refresh is already running...', true, false);
							pollRuntimeStatusOnce();
							return;
						}
						evtSource.close();
						showRefreshError((result.data && result.data.message) || 'refresh failed');
				})
				.catch(function() {
					evtSource.close();
					showRefreshError('server unreachable');
					alert('Server not running.\n\nTo start the server, run:\n  python Hydrophone.py\n\nOr to regenerate without the server:\n  python Hydrophone.py --no-serve');
				});
		}
