			background: color-mix(in srgb, var(--theme-accent-soft, #d7ecff) 38%, var(--theme-surface, #f6f8fb));
		}
		{% if show_issue_management %}
		.dismiss-btn {
			background: none;
			border: 1px solid var(--theme-border, #ced4da);
			border-radius: 999px;
			cursor: pointer;
			padding: 5px 9px;
			color: var(--theme-text-soft, #6c757d);
			font-size: 14px;
		}
		.dismiss-btn:hover { background: #f8d7da; color: #dc3545; border-color: #dc3545; }
		.dismiss-all-btn {
			background: var(--theme-surface, #eef3f8);
			color: var(--theme-text, #1f2a36);
			border: 1px solid var(--theme-border, #ced4da);
			border-radius: 999px;
			padding: 7px 12px;
			cursor: pointer;
			font-size: 12px;
			font-weight: 600;
		}
		.dismiss-all-btn:hover { background: var(--theme-accent-soft, #e7edf4); }
		{% endif %}
		.notifications-empty-state {
			padding: 16px 18px;
			border: 1px dashed var(--theme-border, #ccd4dd);
			border-radius: 14px;
			background: var(--theme-surface, #f6f8fb);
			color: var(--theme-text-muted, #495057);
