			background: #f1f8fb;
		}
		.settings-field.settings-cli-locked label::after {
			content: " (CLI override active)";
			font-weight: 500;
			font-size: 11px;
			color: #117a8b;
		}
		.settings-empty {
			font-size: 12px;
			color: #607182;
			background: #f4f7fa;
			border: 1px dashed #c2ccd7;
			border-radius: 6px;
			padding: 10px;
		}
		.settings-modal-body .cache-modal-actions {
			margin-top: 0;
			flex-shrink: 0;
		}

		/* Theme + navigation refresh */
		html,
		body {
			background: var(--theme-bg);
			color: var(--theme-text);
		}

		body.dashboard-shell,
		body.public-detail-body {
			font-family: var(--font-sans);
			color: var(--theme-text);
			background:
				radial-gradient(circle at top right, rgba(14, 106, 168, 0.1), transparent 28%),
				linear-gradient(180deg, rgba(255, 255, 255, 0.38), transparent 180px),
				var(--theme-bg);
			transition: background-color 0.24s ease, color 0.24s ease;
		}

		html[data-theme="dark"] body.dashboard-shell,
		html[data-theme="dark"] body.public-detail-body {
			background:
				radial-gradient(circle at top right, rgba(124, 199, 255, 0.08), transparent 30%),
				linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 180px),
				var(--theme-bg);
		}

		body.dashboard-shell {
			margin-left: 336px;
			padding: 86px 28px 28px;
		}

		body.public-detail-body {
			padding: 24px;
		}

		a {
			color: var(--theme-accent);
		}

		.top-bar {
			height: 62px;
