			label: actionBtn ? (actionBtn.getAttribute('data-default-label') || 'Refresh Data') : 'Refresh Data',
			pct: 0,
			disabled: false
		});
	}

	function _nextDashboardTheme(theme) {
		return theme === 'dark' ? 'light' : 'dark';
	}

	function _syncThemeButtons() {
		var nextTheme = _nextDashboardTheme(ACTIVE_THEME);
		document.querySelectorAll('[data-theme-toggle]').forEach(function(btn) {
			var label = btn.querySelector('.theme-toggle-label');
			var icon = btn.querySelector('.theme-toggle-icon');
			btn.setAttribute('aria-label', 'Switch to ' + nextTheme + ' mode');
			btn.setAttribute('title', 'Switch to ' + nextTheme + ' mode');
			if (label) {
				label.textContent = nextTheme === 'dark' ? 'Dark mode' : 'Light mode';
			}
			if (icon) {
				icon.textContent = nextTheme === 'dark' ? '☾' : '☀';
			}
		});
	}

	function _broadcastThemeToDetailFrames(theme) {
		var targetOrigin = window.location.origin || '*';
		document.querySelectorAll('iframe.public-detail-frame').forEach(function(frame) {
			try {
				if (frame.contentWindow) {
					frame.contentWindow.postMessage({ type: 'dashboard-theme', theme: theme }, targetOrigin);
				}
			} catch (err) {}
		});
	}

	function applyDashboardTheme(theme, persist) {
		if (theme !== 'light' && theme !== 'dark') {
			theme = 'light';
		}
		ACTIVE_THEME = theme;
		document.documentElement.setAttribute('data-theme', theme);
		document.documentElement.style.colorScheme = theme;
		if (document.body) {
			document.body.setAttribute('data-theme', theme);
		}
		if (persist !== false) {
			try {
				window.localStorage.setItem(THEME_STORAGE_KEY, theme);
			} catch (err) {}
			}
			_syncThemeButtons();
			_broadcastThemeToDetailFrames(theme);
			if (typeof window.restyleArchiveMapsForTheme === 'function') {
				window.restyleArchiveMapsForTheme();
			}
		}

	function toggleDashboardTheme() {
		applyDashboardTheme(_nextDashboardTheme(ACTIVE_THEME), true);
	}

	window.addEventListener('storage', function(event) {
		if (event.key !== THEME_STORAGE_KEY) return;
		if (event.newValue === 'light' || event.newValue === 'dark') {
			applyDashboardTheme(event.newValue, false);
		}
	});

	window.addEventListener('message', function(event) {
		if (event.origin !== window.location.origin) return;
		if (!event.data || event.data.type !== 'dashboard-theme') return;
		if (event.data.theme === 'light' || event.data.theme === 'dark') {
			applyDashboardTheme(event.data.theme, false);
		}
	});

	function canUseVerificationTools() {
		var host = (window.location.hostname || '').toLowerCase();
		var isLocalBrowser = host === 'localhost' || host === '127.0.0.1' || host === '::1' || host === '[::1]';
		return !!VERIFICATION_TOOLS_ENABLED && isLocalBrowser;
	}

	function syncVerificationToolVisibility() {
		var enabled = canUseVerificationTools();
		document.querySelectorAll('[data-local-verification-only="true"]').forEach(function(el) {
			el.hidden = !enabled;
		});
		if (!enabled) closeCacheModal();
	}

	function closeActionsMenu() {
		var menu = document.getElementById('actions-menu');
		if (menu) menu.style.display = 'none';
	}

	function toggleActionsMenu(event) {
		if (event) event.stopPropagation();
		var menu = document.getElementById('actions-menu');
		if (!menu) return;
		menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
	}

	function _getSettingDefinition(key) {
		if (!currentSettingsPayload || !Array.isArray(currentSettingsPayload.settings)) return null;
		for (var i = 0; i < currentSettingsPayload.settings.length; i++) {
			if (currentSettingsPayload.settings[i].key === key) return currentSettingsPayload.settings[i];
		}
		return null;
	}

	function _normalizeSettingValue(defn, raw) {
		if (!defn) return raw;
		if (defn.value_type === 'bool') return !!raw;
		if (defn.value_type === 'int') {
			var parsed = parseInt(raw, 10);
			if (isNaN(parsed)) throw new Error(defn.label + ': enter a whole number.');
			return parsed;
		}
		return raw;
	}

	function _getTimezoneOptions(currentValue) {
		var options = COMMON_TIMEZONES.slice();
		if (currentValue && options.indexOf(currentValue) === -1) options.push(currentValue);
		return options;
	}

	function _renderSettingsCategories(settings) {
		var bar = document.getElementById('settings-category-bar');
		if (!bar) return;
		bar.innerHTML = '';

		var categories = [];
		settings.forEach(function(item) {
			var cat = item.category || 'schedule';
			if (categories.indexOf(cat) === -1) categories.push(cat);
		});
		var order = ['schedule', 'monitoring', 'jira'];
		categories.sort(function(a, b) {
			var ai = order.indexOf(a);
			var bi = order.indexOf(b);
			if (ai === -1 && bi === -1) return a.localeCompare(b);
			if (ai === -1) return 1;
			if (bi === -1) return -1;
			return ai - bi;
		});

		if (!categories.length) return;
		if (!activeSettingsCategory || categories.indexOf(activeSettingsCategory) === -1) {
			activeSettingsCategory = categories[0];
		}

		categories.forEach(function(cat) {
			var btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'settings-category-btn' + (cat === activeSettingsCategory ? ' active' : '');
			btn.textContent = SETTINGS_CATEGORY_LABELS[cat] || cat;
			btn.onclick = function() {
				activeSettingsCategory = cat;
				_renderSettingsForm();
			};
			bar.appendChild(btn);
		});
	}

	function _setLastUpdatedIndicator(isoValue, isUpdating) {
		var el = document.getElementById('last-updated-indicator');
		if (!el) return;
		var text = 'n/a';
		if (isUpdating) {
			text = 'refreshing…';
		} else if (isoValue) {
			text = _formatTopBarDateTime(isoValue);
		}
		el.textContent = text;
		el.classList.toggle('updating', !!isUpdating);
		if (!isUpdating && isoValue) {
			el.setAttribute('data-updated-at', isoValue);
		}
	}

		function initLastUpdatedIndicator() {
			var el = document.getElementById('last-updated-indicator');
			if (!el) return;
			_setLastUpdatedIndicator(el.getAttribute('data-updated-at') || '', false);
		}

		function _setRefreshProgressIndicator(text, isActive, isError) {
			var el = document.getElementById('refresh-progress-indicator');
			if (!el) return;
			if (refreshProgressHideTimer) {
				clearTimeout(refreshProgressHideTimer);
				refreshProgressHideTimer = null;
			}
			if (!text) {
				el.style.display = 'none';
				el.textContent = '';
				el.classList.remove('active');
				el.classList.remove('error');
				return;
			}
			el.style.display = 'inline-block';
			el.textContent = 'Refresh: ' + text;
			el.classList.toggle('active', !!isActive);
			el.classList.toggle('error', !!isError);
		}

		function _hideRefreshProgressIndicator(delayMs) {
			if (refreshProgressHideTimer) clearTimeout(refreshProgressHideTimer);
			refreshProgressHideTimer = setTimeout(function() {
				_setRefreshProgressIndicator('', false, false);
			}, delayMs || 0);
		}

	function _renderAutoRefreshStatus(scheduler) {
		var statusEl = document.getElementById('auto-refresh-status');
		if (!statusEl) return;
		if (!scheduler || !scheduler.enabled) {
			statusEl.textContent = 'off';
			return;
		}
		var nextText = _formatTopBarDateTime(scheduler.next_run_local);
		statusEl.textContent = 'daily ' + scheduler.time + ' · next ' + nextText;
	}

	function _formatRefreshRunningLabel(running) {
		if (!running) return 'Refreshing...';
		var pct = _normalizeRefreshPct(running.pct);
		return pct > 0 ? ('Refreshing ' + pct + '%') : 'Refreshing...';
	}

	function _formatRefreshProgressSummary(refresh) {
		var running = _getEffectiveRefreshRun(refresh);
		if (!running) return '';
		var pct = _normalizeRefreshPct(running.pct);
		var message = String(running.message || 'Refreshing data...');
		return pct > 0 ? (pct + '% ' + message) : message;
	}

	function _renderPublicRefreshButton(publicRefresh, refresh) {
		var btn = document.getElementById('public-refresh-btn');
		if (!btn) return;
		var running = _getEffectiveRefreshRun(refresh);
		if (running) {
			_renderRefreshButtonVisual(btn, {
				state: 'running',
				label: _formatRefreshRunningLabel(running),
				pct: running.pct,
				disabled: true,
				title: running.message
			});
			return;
		}

		if (publicRefresh && publicRefresh.available_now === false) {
			_renderRefreshButtonVisual(btn, {
				state: 'idle',
				label: 'Refresh (' + _formatDurationShort(publicRefresh.seconds_remaining) + ')',
				pct: 0,
				disabled: true,
				title: 'Manual refresh is limited to once every 10 minutes.'
			});
			return;
		}

		_renderRefreshButtonVisual(btn, {
			state: 'idle',
			label: btn.getAttribute('data-default-label') || 'Refresh Data',
			pct: 0,
			disabled: false
		});
	}

	function _renderSchedulerSummary(scheduler) {
		var summary = document.getElementById('settings-scheduler-summary');
		if (!summary) return;
		if (!scheduler || !scheduler.enabled) {
			summary.textContent = 'Automatic refresh is currently disabled.';
			return;
		}
		var text = 'Automatic refresh runs daily at ' + scheduler.time + ' (' + scheduler.timezone + ').';
		text += ' Next run: ' + _formatIsoDateTime(scheduler.next_run_local) + '.';
		if (scheduler.last_status && scheduler.last_status !== 'idle') {
			text += ' Last scheduler status: ' + scheduler.last_status + '.';
		}
		if (scheduler.last_error) {
			text += ' Last error: ' + scheduler.last_error;
		}
		summary.textContent = text;
	}

	function _createSettingInput(setting) {
		var wrapper = document.createElement('div');
		wrapper.className = 'settings-field';
		if (setting.source === 'cli') {
			wrapper.classList.add('settings-cli-locked');
		}
		var hasDraft = Object.prototype.hasOwnProperty.call(settingsDraftValues, setting.key);
		var currentValue = hasDraft ? settingsDraftValues[setting.key] : setting.value;

		var label = document.createElement('label');
		label.textContent = setting.label || setting.key;
		wrapper.appendChild(label);

		var desc = document.createElement('small');
		desc.textContent = setting.description || '';
		wrapper.appendChild(desc);

		var input;
		if (setting.value_type === 'bool') {
			var row = document.createElement('div');
			row.className = 'settings-checkbox-row';
			input = document.createElement('input');
			input.type = 'checkbox';
			input.checked = !!currentValue;
			var text = document.createElement('span');
			text.textContent = input.checked ? 'Enabled' : 'Disabled';
			input.addEventListener('change', function() {
				text.textContent = input.checked ? 'Enabled' : 'Disabled';
				settingsDraftValues[setting.key] = !!input.checked;
			});
			row.appendChild(input);
			row.appendChild(text);
			wrapper.appendChild(row);
		} else {
			if (setting.key === 'auto_refresh_timezone') {
				input = document.createElement('select');
				_getTimezoneOptions(String(currentValue || 'UTC')).forEach(function(zone) {
					var opt = document.createElement('option');
					opt.value = zone;
					opt.textContent = zone;
					input.appendChild(opt);
				});
				input.value = String(currentValue || 'UTC');
			} else {
				input = document.createElement('input');
				if (setting.value_type === 'int') {
					input.type = 'number';
					if (setting.min !== null && setting.min !== undefined) input.min = setting.min;
					if (setting.max !== null && setting.max !== undefined) input.max = setting.max;
				} else if (setting.value_type === 'time') {
					input.type = 'time';
					input.step = 60;
				} else {
					input.type = 'text';
				}
				input.value = currentValue !== null && currentValue !== undefined ? String(currentValue) : '';
			}
			input.addEventListener('input', function() {
				settingsDraftValues[setting.key] = input.value;
			});
			input.addEventListener('change', function() {
				settingsDraftValues[setting.key] = input.value;
			});
			wrapper.appendChild(input);
		}

		input.dataset.settingKey = setting.key;
		input.dataset.valueType = setting.value_type;
		if (setting.source === 'cli') {
			input.disabled = true;
		}

		var source = document.createElement('div');
		source.className = 'settings-source';
		source.textContent = 'Current source: ' + _sourceText(setting.source);
		wrapper.appendChild(source);

		return wrapper;
	}

	function _renderSettingsForm(payload) {
		if (payload) {
			currentSettingsPayload = payload;
		}
		if (!currentSettingsPayload) return;

		var form = document.getElementById('settings-form');
		if (!form) return;
		form.innerHTML = '';
		var settings = (currentSettingsPayload && currentSettingsPayload.settings) || [];
		_renderSettingsCategories(settings);
		var visible = settings.filter(function(setting) {
			return (setting.category || 'schedule') === activeSettingsCategory;
		});
		if (!visible.length) {
			var empty = document.createElement('div');
			empty.className = 'settings-empty';
			empty.textContent = 'No settings in this category.';
			form.appendChild(empty);
		}
		visible.forEach(function(setting) {
			form.appendChild(_createSettingInput(setting));
		});
		_renderSchedulerSummary(currentSettingsPayload ? currentSettingsPayload.scheduler : null);
		_renderAutoRefreshStatus(currentSettingsPayload ? currentSettingsPayload.scheduler : null);
	}

		function loadDashboardSettings() {
			return fetch(buildDashboardUrl('/api/settings'))
				.then(function(resp) { return resp.json(); })
				.then(function(data) {
					if (!data || data.status !== 'ok') return;
					currentSettingsPayload = data;
					settingsDraftValues = {};
					_renderSettingsForm();
					_applyRuntimeStatus(data);
				})
				.catch(function() {});
		}

		function _applyRuntimeStatus(payload) {
			if (!payload) return;
			var scheduler = payload.scheduler || null;
			var refresh = payload.refresh || null;
			var publicRefresh = payload.public_refresh || null;

			_renderPublicRefreshButton(publicRefresh, refresh);
			_renderOperatorRefreshControls(refresh);

			if (scheduler) {
				_renderAutoRefreshStatus(scheduler);
				var modal = document.getElementById('settings-modal');
				if (modal && modal.style.display !== 'none') {
					_renderSchedulerSummary(scheduler);
				}
			}

			if (!refresh) return;

			var lastUpdatedEl = document.getElementById('last-updated-indicator');
			if (!lastUpdatedEl) {
				// Detail pages do not have a dashboard timestamp; without this guard a
				// completed refresh looks stale forever and the widget page reloads in a loop.
				if (refresh.last_status === 'running') {
					_setRefreshProgressIndicator(_formatRefreshProgressSummary(refresh), true, false);
				}
				return;
			}
			var currentUpdatedAt = lastUpdatedEl ? (lastUpdatedEl.getAttribute('data-updated-at') || '') : '';
			var currentUpdatedMs = _isoToMs(currentUpdatedAt);
			var startedMs = _isoToMs(refresh.last_started_at || '');
			var finishedAt = refresh.last_finished_at || '';
			var trigger = refresh.last_trigger || 'manual';
			var pageIsStaleForLatestRefresh = false;

			if (isNaN(currentUpdatedMs)) {
				pageIsStaleForLatestRefresh = !!finishedAt;
			} else if (!isNaN(startedMs)) {
				// If page timestamp is older than latest refresh start, this page is stale.
				pageIsStaleForLatestRefresh = currentUpdatedMs < startedMs;
			} else {
				// Fallback when start time is missing.
				pageIsStaleForLatestRefresh = finishedAt && finishedAt !== currentUpdatedAt;
			}

			if (refresh.last_status === 'running') {
				if (manualRefreshInProgress) {
					_setManualRefreshState(true, refresh.progress_pct, refresh.progress_message);
				}
				_setRefreshProgressIndicator(_formatRefreshProgressSummary(refresh), true, false);
				return;
			}

			if (refresh.last_status === 'ok' && finishedAt) {
				var isNewFinishedEvent = finishedAt !== lastProcessedRefreshFinishedAt;
				if (manualRefreshInProgress) {
					_setManualRefreshState(false, 0, '');
				}
				if (finishedAt !== currentUpdatedAt) {
					_setLastUpdatedIndicator(finishedAt, false);
				}
				if (isNewFinishedEvent) {
					if (pageIsStaleForLatestRefresh) {
						var reloadMessage = trigger === 'scheduled' ? 'auto refresh complete. Reloading...' : 'refresh complete. Reloading...';
						_setRefreshProgressIndicator(reloadMessage, false, false);
						if (!scheduledReloadTimer) {
							scheduledReloadTimer = setTimeout(function() {
								scheduledReloadTimer = null;
								window.location.reload();
							}, 1800);
						}
					} else {
						_setRefreshProgressIndicator(trigger === 'scheduled' ? 'auto refresh complete' : 'refresh complete', false, false);
						_hideRefreshProgressIndicator(6000);
					}
				}
				lastProcessedRefreshFinishedAt = finishedAt;
				return;
			}

			if (refresh.last_status === 'error' && refresh.last_error) {
				if (manualRefreshInProgress) {
					_setManualRefreshState(false, 0, '');
				}
				var prefix = trigger === 'scheduled' ? 'auto refresh failed: ' : 'refresh failed: ';
				_setRefreshProgressIndicator(prefix + refresh.last_error, false, true);
				_hideRefreshProgressIndicator(10000);
			}
		}

		function pollRuntimeStatusOnce() {
			return fetch(buildDashboardUrl('/api/runtime-status'))
				.then(function(resp) { return resp.json(); })
				.then(function(data) {
					if (!data || data.status !== 'ok') return;
					_applyRuntimeStatus(data);
				})
				.catch(function() {});
		}

		function startRuntimeStatusPolling() {
			if (runtimeStatusPollTimer) return;
			pollRuntimeStatusOnce();
			runtimeStatusPollTimer = setInterval(pollRuntimeStatusOnce, 3000);
		}

	function openSettingsModal() {
		closeActionsMenu();
		var modal = document.getElementById('settings-modal');
		if (modal) modal.style.display = 'flex';
		loadDashboardSettings();
	}

	function closeSettingsModal() {
		var modal = document.getElementById('settings-modal');
		if (modal) modal.style.display = 'none';
	}

	function _collectSettingsUpdates() {
		var updates = {};
		Object.keys(settingsDraftValues).forEach(function(key) {
			var defn = _getSettingDefinition(key);
			if (!defn || defn.source === 'cli') return;
			var normalized = _normalizeSettingValue(defn, settingsDraftValues[key]);
			if (defn.value_type === 'int') {
				if (defn.min !== null && defn.min !== undefined && normalized < defn.min) {
					throw new Error(defn.label + ' must be at least ' + defn.min + '.');
				}
				if (defn.max !== null && defn.max !== undefined && normalized > defn.max) {
					throw new Error(defn.label + ' must be at most ' + defn.max + '.');
				}
			}
			updates[key] = normalized;
		});
		return updates;
	}

	function saveDashboardSettings() {
		var btn = document.getElementById('settings-save-btn');
		if (btn) btn.disabled = true;

		var updates;
		try {
			updates = _collectSettingsUpdates();
		} catch (e) {
			if (btn) btn.disabled = false;
			alert(e.message || 'Invalid settings.');
			return;
		}
		if (!Object.keys(updates).length) {
			if (btn) btn.disabled = false;
			alert('No unsaved setting changes.');
			return;
		}

		fetch(buildDashboardUrl('/api/settings'), {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ values: updates })
		})
			.then(function(resp) {
				return resp.json().then(function(data) {
					return { ok: resp.ok, data: data };
				});
			})
			.then(function(result) {
				if (!result.ok || !result.data || result.data.status !== 'ok') {
					throw new Error((result.data && result.data.message) || 'Failed to save settings.');
				}
				currentSettingsPayload = result.data;
				settingsDraftValues = {};
				_renderSettingsForm();
				alert('Settings saved. New values apply on the next refresh run. CLI overrides still take priority if active.');
			})
			.catch(function(e) {
				alert(e.message || 'Could not save settings.');
			})
			.finally(function() {
				if (btn) btn.disabled = false;
			});
	}

	// Prevent widget cascade failures by isolating each widget
	(function() {
		// Override console.error to catch widget errors
		const originalError = console.error;
		console.error = function(...args) {
			// Log the error but don't let it break subsequent widgets
			originalError.apply(console, args);
		};

		const pendingWidgetContainers = new Set();
		const WIDGET_RESCAN_COOLDOWN_MS = 15000;

		function isWidgetLoading(widget) {
			if (!widget) return false;
			const lowerText = (widget.textContent || "").toLowerCase();
			return lowerText.includes("requesting archive files") || lowerText.includes("waiting for other widgets");
		}

		function getWidgetLastScanAt(widget) {
			if (!widget) return 0;
			return Number(widget.getAttribute("data-widget-last-scan-at") || "0");
		}

		function markWidgetScan(widget) {
			if (!widget) return;
			var scanCount = Number(widget.getAttribute("data-widget-scan-count") || "0") + 1;
			widget.setAttribute("data-widget-last-scan-at", String(Date.now()));
			widget.setAttribute("data-widget-scan-count", String(scanCount));
		}

		function canScanWidget(widget, force) {
			if (!widget) return;
			if (!widget.getAttribute("data-widget")) return;
			if (!force && widget.getAttribute("data-oncdw-processed") === "true") return false;
			var lastScanAt = getWidgetLastScanAt(widget);
			if (!force) {
				return lastScanAt === 0;
			}
			if (!lastScanAt) return true;
			if (isWidgetLoading(widget)) return false;
			return (Date.now() - lastScanAt) >= WIDGET_RESCAN_COOLDOWN_MS;
		}

		function withOnlyWidgetVisibleToOncDW(widget, callback) {
			var stashed = [];
			document.querySelectorAll(".oncWidget").forEach(function(other) {
				if (other === widget) return;
				stashed.push([other, other.getAttribute("class") || ""]);
				other.classList.remove("oncWidget");
			});
			try {
				callback();
			} finally {
				stashed.forEach(function(item) {
					item[0].setAttribute("class", item[1]);
				});
			}
		}

		function scanWidgetWithOncDW(widget) {
			if (!window.OncDW || typeof window.OncDW.detectWidgets !== "function") return false;
			var beforeCount = Array.isArray(window.OncDW._widgets) ? window.OncDW._widgets.length : 0;
			withOnlyWidgetVisibleToOncDW(widget, function() {
				window.OncDW.detectWidgets();
			});
			var afterCount = Array.isArray(window.OncDW._widgets) ? window.OncDW._widgets.length : beforeCount;
			if (afterCount <= beforeCount) return false;
			widget.setAttribute("data-oncdw-processed", "true");
			for (var idx = beforeCount; idx < afterCount; idx++) {
				if (typeof window.OncDW.processWidget === "function") {
					window.OncDW.processWidget(idx);
				}
			}
			return true;
		}

		function scanWidget(widget, force) {
			if (!canScanWidget(widget, !!force)) return false;
			if (window.oncdw && typeof window.oncdw.scan === "function") {
				markWidgetScan(widget);
				if (window.oncdw.scan(widget) === false) return false;
				widget.setAttribute("data-oncdw-processed", "true");
				return true;
			}
			markWidgetScan(widget);
