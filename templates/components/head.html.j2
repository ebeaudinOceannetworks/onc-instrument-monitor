						layer.batchDraw();
					}
				});
				restyleArchiveMapLegendBoxes(widgetInstance);
				restyleArchiveMapDaySeparators(widgetInstance, isDark);

				try {
					findKonvaNodes(widgetInstance.map.lyrUI).forEach(function(node) {
						if (
							getKonvaClassName(node) !== 'Label' ||
							typeof node.getAttr !== 'function' ||
							typeof node.setAttr !== 'function' ||
							node.getAttr('data-hydrophone-themed')
						) return;
						node.setAttr('data-hydrophone-themed', true);
						var parent = typeof node.getParent === 'function' ? node.getParent() : null;
						if (!parent || typeof parent.on !== 'function') return;
						parent.on('mouseenter.hydrophoneTheme mouseleave.hydrophoneTheme click.hydrophoneTheme', function() {
							setTimeout(function() {
								restyleArchiveMapForTheme(widgetInstance);
							}, 0);
						});
					});
				} catch (e) {}
			}

			function attachArchiveMapStyleHooks(widgetInstance) {
				var map = widgetInstance && widgetInstance.map;
				if (!map || map.__hydrophoneStyleHooksAttached) return;
				map.__hydrophoneStyleHooksAttached = true;
				if (typeof map.updateZoom === 'function') {
					var originalUpdateZoom = map.updateZoom;
					map.updateZoom = function() {
						var result = originalUpdateZoom.apply(this, arguments);
						setTimeout(function() {
							redrawArchiveMapWidget(widgetInstance);
							restyleArchiveMapForTheme(widgetInstance);
						}, 0);
						return result;
					};
				}
			}

			function restyleArchiveMapsForTheme() {
				if (!window.OncDW || !Array.isArray(window.OncDW._widgets)) return;
				window.OncDW._widgets.forEach(function(widgetInstance) {
					if (
						widgetInstance &&
						widgetInstance.dom &&
						widgetInstance.dom.base &&
						widgetInstance.dom.base.getAttribute('data-widget') === 'archiveMap'
					) {
						restyleArchiveMapForTheme(widgetInstance);
					}
				});
			}
			window.restyleArchiveMapsForTheme = restyleArchiveMapsForTheme;

			function scheduleArchiveMapRedraws(widgetInstance) {
				if (!widgetInstance || !widgetInstance.map) return;
				sanitizeArchiveWidgetDownloads(widgetInstance);
				patchArchiveMapTooltipDuration(widgetInstance);
				attachArchiveMapStyleHooks(widgetInstance);
				redrawArchiveMapWidget(widgetInstance);
				restyleArchiveMapForTheme(widgetInstance);
				if (typeof window.requestAnimationFrame === 'function') {
					window.requestAnimationFrame(function() {
						redrawArchiveMapWidget(widgetInstance);
						restyleArchiveMapForTheme(widgetInstance);
					});
				}
				setTimeout(function() {
					redrawArchiveMapWidget(widgetInstance);
					restyleArchiveMapForTheme(widgetInstance);
				}, 80);
				setTimeout(function() {
					redrawArchiveMapWidget(widgetInstance);
					restyleArchiveMapForTheme(widgetInstance);
				}, 250);
			}

		function extendArchiveMapWidgetRange(widgetInstance) {
			if (!widgetInstance || !widgetInstance.map || !widgetInstance.map.range) return;
			var widget = widgetInstance.dom && widgetInstance.dom.base;
			if (!widget || widget.getAttribute('data-widget') !== 'archiveMap') return;

			var map = widgetInstance.map;
			var desiredMax = getArchiveMapDesiredRangeMax(widgetInstance);
			if (!Number.isFinite(desiredMax)) return;
			if (Number(map.range.max || 0) >= desiredMax - 1000) return;

			try {
				map.range.max = desiredMax;
				map.computeDayRanges();
				map.zoomUpdateLayout();
				if (map.lyrUI && typeof map.lyrUI.destroy === 'function' && typeof map.buildLayerUI === 'function') {
					var stage = typeof map.lyrUI.getStage === 'function' ? map.lyrUI.getStage() : null;
					if (stage) {
						map.lyrUI.destroy();
						map.lyrUI = map.buildLayerUI(map.layout, map.layout.row);
						stage.add(map.lyrUI);
					}
				}
				if (map.backMap && typeof map.backMap.rebuild === 'function') {
					map.backMap.rebuild(map.layout.area, map.layout.row);
				}
				if (map.scrollbar && typeof map.scrollbar.update === 'function') {
					var scrollX = 0;
					if (map.lyrMap && typeof map.lyrMap.x === 'function') {
						scrollX = Math.abs(map.lyrMap.x() || 0);
					}
					map.scrollbar.update(map.layout.area.w, scrollX);
				}
				widget.setAttribute('data-archive-map-extended', 'true');
				scheduleArchiveMapRedraws(widgetInstance);
			} catch (e) {
				console.log('Archive map range extension failed:', e);
			}
		}

		function refreshWidgetsWhenDetailsVisible() {
			function recoverPass() {
				window.dispatchEvent(new Event('resize'));
				const recoverableWidgets = document.querySelectorAll('#details-tab-panel .oncWidget[data-widget="archiveFiles"], #details-tab-panel .oncWidget[data-widget="archiveMap"]');
				recoverableWidgets.forEach(function(widget) {
					if (widgetNeedsRecovery(widget)) {
						recoverWidget(widget);
					}
				});
			}

			setTimeout(recoverPass, 220);
			setTimeout(recoverPass, 1400);
		}

		function scanVisibleDetailWidgets() {
			const containers = document.querySelectorAll('#details-tab-panel .widget-container');
			containers.forEach(function(container, index) {
				setTimeout(function() {
					scanContainerWhenVisible(container);
				}, index * 120);
			});
		}

		// Add global error handler
		window.addEventListener("error", function(e) {
			console.log("Widget error caught and isolated:", e.message);
			return true; // Prevent error from bubbling
		});

		document.addEventListener("hydrophone:details-visible", function() {
			rescanDeferredContainers();
			scanVisibleDetailWidgets();
			refreshWidgetsWhenDetailsVisible();
			patchWindowOpenForArchiveDownloads();
			sanitizeAllArchiveDownloads();
		});

		document.addEventListener("OncWidgetDownloaded", function(event) {
			try {
				var detail = event && event.detail;
				var idx = detail && detail.idx;
				if (idx === undefined || !window.OncDW || !Array.isArray(window.OncDW._widgets)) return;
				var widgetInstance = window.OncDW._widgets[idx];
				if (!widgetInstance || !widgetInstance.dom || !widgetInstance.dom.base) return;
				sanitizeArchiveWidgetDownloads(widgetInstance);
				if (widgetInstance.dom.base.getAttribute('data-widget') !== 'archiveMap') return;
				setTimeout(function() {
					sanitizeArchiveWidgetDownloads(widgetInstance);
					scheduleArchiveMapRedraws(widgetInstance);
					finishArchiveMapRefresh(widgetInstance.dom.base);
				}, 0);
			} catch (e) {
				console.log('Archive map post-processing failed:', e);
			}
		});

		// Initialize widgets with error boundaries
		document.addEventListener("DOMContentLoaded", function() {
			patchWindowOpenForArchiveDownloads();
			sanitizeAllArchiveDownloads();
			document.addEventListener('click', function(event) {
				var target = event.target;
				var link = target && target.closest ? target.closest('a[href*="archivefiles"][href*="method=getFile"]') : null;
				if (link) rewriteArchiveDownloadLink(link);
			}, true);
			if (typeof MutationObserver === 'function') {
				var archiveDownloadObserver = new MutationObserver(function(mutations) {
					mutations.forEach(function(mutation) {
						if (mutation.type === 'childList') {
							mutation.addedNodes.forEach(function(node) {
								if (node && node.nodeType === 1) {
									sanitizeAllArchiveDownloads(node);
								}
							});
						} else if (
							mutation.type === 'attributes' &&
							mutation.target &&
							mutation.target.matches &&
							mutation.target.matches('a[href*="archivefiles"]')
						) {
							rewriteArchiveDownloadLink(mutation.target);
						}
					});
				});
				archiveDownloadObserver.observe(document.body, {
					childList: true,
					subtree: true,
					attributes: true,
					attributeFilter: ['href']
				});
			}

			// Add progressive widget loading with delays
			if (!isPublicDetailPage()) {
				const widgetContainers = document.querySelectorAll(".widget-container");

				widgetContainers.forEach(function(container, index) {
					setTimeout(function() {
						scanContainerWhenVisible(container);
					}, index * 500); // Stagger widget loading
				});
			}

			// Check for failed widgets and mark them
			setTimeout(function() {
				const widgets = document.querySelectorAll(".oncWidget");
				widgets.forEach(function(widget) {
					if (widget.innerHTML.trim() === "" || widget.textContent.includes("No data preview image could be found")) {
						const errorDiv = document.createElement("div");
						errorDiv.className = "widget-error-indicator";
						errorDiv.textContent = "⚠ No data available for this widget";
						widget.parentNode.insertBefore(errorDiv, widget.nextSibling);
						widget.style.display = "none";
					}
				});
			}, 12000);
		});
	})();

	{% if show_public_notifications|default(dashboard_variant == 'public', true) %}
	var PUBLIC_NOTIFICATIONS_SEEN_STORAGE_KEY = 'hydrophoneDashboard.publicNotificationsSeen.v1';
	var publicNotificationsPayload = null;

	function _getNotificationsElements() {
		return {
			dropdown: document.getElementById('notifications-dropdown'),
			toggle: document.getElementById('notifications-toggle'),
			panel: document.getElementById('notifications-panel'),
			count: document.getElementById('notifications-count'),
			title: document.getElementById('notifications-title'),
			summary: document.getElementById('public-notifications-summary'),
			list: document.getElementById('notifications-list')
		};
	}

	function _getPublicNotificationId(notification) {
		if (!notification) return '';
		return notification.id || [
			notification.locationCode || '',
			notification.status || '',
			notification.message || '',
			notification.event_at || notification.first_seen || ''
		].join('|');
	}

	function _readSeenPublicNotificationIds() {
		try {
			var raw = window.localStorage.getItem(PUBLIC_NOTIFICATIONS_SEEN_STORAGE_KEY);
			var parsed = raw ? JSON.parse(raw) : [];
			return new Set(Array.isArray(parsed) ? parsed : []);
		} catch (e) {
			return new Set();
		}
	}

	function _writeSeenPublicNotificationIds(ids) {
		try {
			window.localStorage.setItem(PUBLIC_NOTIFICATIONS_SEEN_STORAGE_KEY, JSON.stringify(Array.from(ids)));
		} catch (e) {}
	}

	function _pruneSeenPublicNotificationIds(activeIds) {
		var active = new Set(activeIds || []);
		var seen = _readSeenPublicNotificationIds();
		var pruned = new Set();
		seen.forEach(function(id) {
			if (active.has(id)) pruned.add(id);
		});
		if (pruned.size !== seen.size) _writeSeenPublicNotificationIds(pruned);
		return pruned;
	}

	function _readEmbeddedPublicNotifications() {
		var script = document.getElementById('public-notifications-data');
		if (!script) return { notifications: [], total: 0, today_count: 0, window_days: 7 };
		try {
			var parsed = JSON.parse(script.textContent || '{}');
			return parsed && typeof parsed === 'object' ? parsed : { notifications: [], total: 0, today_count: 0, window_days: 7 };
		} catch (e) {
			return { notifications: [], total: 0, today_count: 0, window_days: 7 };
		}
	}

	function _publicNotificationTitle(total, windowDays) {
		if (!total) return 'No recent notifications';
		return total + ' in last ' + windowDays + ' days';
	}

	function _isPublicNotificationToday(notification) {
		if (notification && notification.is_today === true) return true;
		var value = notification && (notification.event_at || notification.first_seen);
		if (!value) return false;
		var parsed = new Date(value);
		if (isNaN(parsed.getTime())) return false;
		var now = new Date();
		return parsed.getFullYear() === now.getFullYear() &&
			parsed.getMonth() === now.getMonth() &&
			parsed.getDate() === now.getDate();
	}

	function _formatPublicNotificationTime(notification) {
		var value = notification && (notification.event_at || notification.first_seen || '');
		if (!value) return 'Unknown';
		return String(value).slice(0, 16).replace('T', ' ');
	}

	function _setPublicNotificationState(total, unseen, todayCount, windowDays) {
		var els = _getNotificationsElements();
		if (els.count) {
			els.count.textContent = String(unseen > 0 ? unseen : total);
			els.count.classList.toggle('is-empty', unseen === 0);
			els.count.title = unseen > 0 ? unseen + ' unseen notification' + (unseen !== 1 ? 's' : '') : total + ' recent notification' + (total !== 1 ? 's' : '');
		}
		if (els.title) {
			els.title.textContent = _publicNotificationTitle(total, windowDays);
		}
		if (els.summary) {
			els.summary.textContent = todayCount > 0
				? todayCount + ' today'
				: 'Updated with the dashboard refresh';
		}
		if (els.toggle) {
			els.toggle.classList.toggle('has-unseen', unseen > 0);
			els.toggle.classList.toggle('has-today', todayCount > 0);
			els.toggle.setAttribute(
				'aria-label',
				unseen > 0
					? unseen + ' unseen public notification' + (unseen !== 1 ? 's' : '')
					: total + ' public notification' + (total !== 1 ? 's' : '')
			);
		}
	}

	function _renderPublicNotificationsEmpty(windowDays) {
		var els = _getNotificationsElements();
		if (!els.list) return;
		els.list.innerHTML = '';
		var empty = document.createElement('div');
		empty.className = 'notifications-empty-state';
		var copy = document.createElement('p');
		copy.textContent = 'Nothing new has been detected in the last ' + windowDays + ' days.';
		empty.appendChild(copy);
		els.list.appendChild(empty);
	}

	function _renderPublicNotifications(payload) {
		payload = payload || { notifications: [], total: 0, today_count: 0, window_days: 7 };
		var notifications = Array.isArray(payload.notifications) ? payload.notifications : [];
		var windowDays = payload.window_days || 7;
		publicNotificationsPayload = {
			notifications: notifications,
			total: notifications.length,
			today_count: payload.today_count || 0,
			window_days: windowDays
		};

		var activeIds = notifications.map(_getPublicNotificationId).filter(Boolean);
		var seen = _pruneSeenPublicNotificationIds(activeIds);
		var unseen = activeIds.filter(function(id) { return !seen.has(id); }).length;
		var todayCount = typeof payload.today_count === 'number'
			? payload.today_count
			: notifications.filter(_isPublicNotificationToday).length;
		_setPublicNotificationState(notifications.length, unseen, todayCount, windowDays);

		var els = _getNotificationsElements();
		if (!els.list) return;
		if (notifications.length === 0) {
			_renderPublicNotificationsEmpty(windowDays);
			return;
		}

		var statusColors = { critical: '#dc3545', error: '#dc3545', warning: '#fd7e14', minor: '#ffc107' };
		var statusIcons = { critical: '✗', error: '!', warning: '!', minor: '!' };
		els.list.innerHTML = '';
		notifications.forEach(function(notification) {
			var status = notification.status || 'unknown';
			var notificationId = _getPublicNotificationId(notification);
			var item = document.createElement('div');
			item.className = 'new-issue-item notifications-issue-item public-notification-item';
			item.dataset.notificationId = notificationId;
			item.classList.toggle('is-unseen', !!notificationId && !seen.has(notificationId));
			item.style.borderLeft = '4px solid ' + (statusColors[status] || '#6c757d');

			var severity = document.createElement('div');
			severity.className = 'issue-severity';
			severity.style.backgroundColor = (statusColors[status] || '#6c757d');
			severity.textContent = (statusIcons[status] || '?') + ' ' + String(status).toUpperCase();
			item.appendChild(severity);

			var details = document.createElement('div');
			details.className = 'issue-details';

			var link = document.createElement('button');
			link.type = 'button';
			link.className = 'issue-location-link';
			link.textContent = notification.locationCode || 'Unknown';
			link.setAttribute('data-open-detail-location', notification.locationCode || '');
			details.appendChild(link);

			var message = document.createElement('span');
			message.className = 'issue-message';
			message.textContent = notification.message || '';
			details.appendChild(message);

			var since = document.createElement('span');
			since.className = 'issue-since';
			if (_isPublicNotificationToday(notification)) {
				var today = document.createElement('span');
				today.className = 'public-notification-today';
				today.textContent = 'Today';
				since.appendChild(today);
			}
			since.appendChild(document.createTextNode('Since: ' + _formatPublicNotificationTime(notification)));
			details.appendChild(since);

			item.appendChild(details);
			els.list.appendChild(item);
		});
	}

	function markPublicNotificationsSeen() {
		var notifications = publicNotificationsPayload && Array.isArray(publicNotificationsPayload.notifications)
			? publicNotificationsPayload.notifications
			: [];
		var ids = notifications.map(_getPublicNotificationId).filter(Boolean);
		_writeSeenPublicNotificationIds(new Set(ids));
		_renderPublicNotifications(publicNotificationsPayload);
	}

	function _setNotificationsPanelOpen(isOpen) {
		var els = _getNotificationsElements();
		if (!els.panel || !els.toggle) return;
		els.panel.hidden = !isOpen;
		els.toggle.setAttribute('aria-expanded', String(!!isOpen));
		els.dropdown && els.dropdown.classList.toggle('is-open', !!isOpen);
		document.body && document.body.classList.toggle('notifications-layer-open', !!isOpen);
		if (isOpen) markPublicNotificationsSeen();
	}

	function closeNotificationsPanel() {
		_setNotificationsPanelOpen(false);
	}

	function togglePublicNotificationsPanel(event) {
		if (event) {
			event.preventDefault();
			event.stopPropagation();
		}
		var els = _getNotificationsElements();
		if (!els.panel || !els.toggle) return;
		var isOpen = els.toggle.getAttribute('aria-expanded') === 'true';
		_setNotificationsPanelOpen(!isOpen);
	}

	function refreshPublicNotifications() {
		fetch(buildDashboardUrl('/api/public-notifications'))
			.then(function(resp) { return resp.json(); })
			.then(function(data) {
				if (!data || !Array.isArray(data.notifications)) return;
				_renderPublicNotifications(data);
			})
			.catch(function() {});
	}

	function initPublicNotifications() {
		_renderPublicNotifications(_readEmbeddedPublicNotifications());
		refreshPublicNotifications();
		document.addEventListener('click', function(event) {
			var els = _getNotificationsElements();
			if (!els.dropdown || !els.panel || els.panel.hidden) return;
			if (els.dropdown.contains(event.target)) return;
			closeNotificationsPanel();
		});
		document.addEventListener('keydown', function(event) {
			if (event.key === 'Escape') closeNotificationsPanel();
		});
	}
