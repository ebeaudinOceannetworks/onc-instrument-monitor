		if (!canUseVerificationTools()) return;
		closeActionsMenu();
		var modal = document.getElementById('cache-modal');
		if (modal) modal.style.display = 'flex';
		showCacheProgress(false);
		var summary = document.getElementById('cache-analysis-summary');
		if (summary) summary.textContent = 'Run analysis to see counts.';
		var list = document.getElementById('cache-label-list');
		if (list) list.innerHTML = '';
		var copyBtn = document.getElementById('cache-copy-btn');
		if (copyBtn) copyBtn.disabled = true;
		var analyzeBtn = document.getElementById('cache-analyze-btn');
		if (analyzeBtn) {
			analyzeBtn.disabled = false;
			analyzeBtn.classList.remove('loading');
		}
		loadCacheConfig();
		var includeVerified = document.getElementById('cache-include-verified');
		var includeAudio = document.getElementById('cache-include-audio');
		if (includeVerified && !includeVerified.dataset.cacheBound) {
			includeVerified.addEventListener('change', scheduleSelectionRecalc);
			includeVerified.dataset.cacheBound = 'true';
		}
		if (includeAudio && !includeAudio.dataset.cacheBound) {
			includeAudio.addEventListener('change', scheduleSelectionRecalc);
			includeAudio.dataset.cacheBound = 'true';
