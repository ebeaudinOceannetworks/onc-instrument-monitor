			display: inline-flex;
			align-items: center;
			gap: 6px;
			white-space: nowrap;
			cursor: pointer;
		}
		.settings-btn:hover { background-color: #243b53; }
		.settings-btn[disabled] {
			opacity: 0.72;
			cursor: not-allowed;
		}
		.settings-btn.refreshing {
			background-color: #7c5d00;
		}

		/* Cache modal */
		.cache-modal {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background: rgba(0, 0, 0, 0.4);
			z-index: 2000;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.cache-modal-content {
			background: #fff;
			border-radius: 10px;
			width: 420px;
			max-width: calc(100% - 40px);
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
		}
		.cache-modal-content.cache-modal-wide {
			width: 860px;
		}
		.cache-modal-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 14px 16px;
			border-bottom: 1px solid #e9ecef;
		}
		.cache-modal-header h3 {
			margin: 0;
			font-size: 16px;
		}
		.cache-modal-close {
			background: none;
			border: none;
			font-size: 20px;
			cursor: pointer;
			color: #6c757d;
		}
		.cache-modal-body {
			padding: 16px;
		}
		.cache-modal-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 28px;
		}
		.cache-modal-section + .cache-modal-section {
			border-left: 1px solid #e9ecef;
			padding-left: 20px;
		}
		.cache-modal-section h4 {
			margin: 0 0 10px 0;
			font-size: 14px;
			color: #343a40;
		}
		.cache-label {
			font-size: 12px;
			color: #6c757d;
			margin-top: 10px;
			display: block;
		}
		.cache-input, .cache-textarea, .cache-modal-section select {
			width: 100%;
			border: 1px solid #ced4da;
			border-radius: 6px;
			padding: 6px 8px;
			font-size: 13px;
			margin-top: 4px;
		}
		.cache-textarea {
			font-family: monospace;
		}
		.cache-checkbox-row {
			display: flex;
			gap: 12px;
			margin-top: 10px;
			font-size: 12px;
			color: #495057;
		}
		.cache-modal-actions {
			margin-top: 12px;
			display: flex;
			gap: 8px;
		}
		.cache-btn {
			border: none;
			border-radius: 5px;
			padding: 6px 12px;
			font-size: 12px;
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}
		.cache-btn[disabled] {
			opacity: 0.6;
			cursor: default;
		}
		.cache-btn-spinner {
			width: 12px;
			height: 12px;
			border: 2px solid rgba(255, 255, 255, 0.4);
			border-top-color: #fff;
			border-radius: 50%;
			display: none;
			animation: cache-spin 0.8s linear infinite;
		}
		.cache-btn.loading .cache-btn-spinner {
			display: inline-block;
		}
		.cache-btn.loading .cache-btn-text {
			opacity: 0.9;
		}
		@keyframes cache-spin {
			from { transform: rotate(0deg); }
			to { transform: rotate(360deg); }
		}
		.cache-btn-primary { background: #007bff; color: #fff; }
		.cache-btn-success { background: #28a745; color: #fff; }
		.cache-btn-light { background: #f1f3f5; color: #495057; }
		.cache-analysis-summary {
			font-size: 12px;
			color: #495057;
			background: #f8f9fa;
			border-radius: 6px;
			padding: 8px;
			margin-bottom: 10px;
		}
		.cache-label-actions {
			display: flex;
			gap: 6px;
			margin-bottom: 8px;
		}
		.cache-label-list {
			max-height: 260px;
			overflow-y: auto;
			border: 1px solid #e9ecef;
			border-radius: 6px;
			padding: 6px;
			font-size: 12px;
		}
		.cache-label-item {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 4px 2px;
			border-bottom: 1px dashed #e9ecef;
		}
		.cache-label-item--nested {
			padding-left: 12px;
		}
		.cache-label-item:last-child { border-bottom: none; }
		.cache-label-name { font-family: monospace; font-size: 11px; }
		.cache-label-count { color: #6c757d; font-size: 11px; }
		.cache-device-group {
			border: 1px solid #eef1f4;
			border-radius: 6px;
			padding: 6px;
			margin-bottom: 8px;
			background: #fff;
		}
		.cache-device-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			font-weight: 600;
			margin-bottom: 4px;
		}
		.cache-device-name { font-size: 12px; }
		.cache-device-labels { margin-left: 4px; }
		.cache-progress-block {
			margin-top: 12px;
		}
		.cache-modal-message {
			font-size: 13px;
			color: #495057;
			margin-bottom: 12px;
		}
		.cache-progress {
			width: 100%;
			height: 10px;
			background: #e9ecef;
			border-radius: 999px;
			overflow: hidden;
			margin-bottom: 10px;
		}
		.cache-progress-bar {
			height: 100%;
			background: #17a2b8;
			width: 0%;
			transition: width 0.2s ease;
		}
		.cache-progress-text {
			font-size: 12px;
			color: #6c757d;
			text-align: right;
		}
		.settings-modal-content {
			width: 620px;
			max-width: calc(100% - 40px);
			height: min(760px, calc(100vh - 32px));
			display: flex;
			flex-direction: column;
