		.settings-note {
			margin: 0;
			font-size: 12px;
			color: #445566;
			background: #eef3f8;
			border: 1px solid #d1dbe6;
			border-radius: 6px;
			padding: 8px 10px;
		}
		.settings-scheduler-summary {
			font-size: 12px;
			color: #273444;
			background: #f2f7fb;
			border: 1px solid #c9d8e6;
			border-radius: 6px;
			padding: 10px;
			margin-bottom: 0;
		}
		.settings-category-bar {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			margin-bottom: 12px;
		}
		.settings-category-btn {
			border: 1px solid #aab8c5;
			background: #f3f6f9;
			color: #263849;
			border-radius: 999px;
			padding: 6px 12px;
			font-size: 12px;
			font-weight: 600;
			cursor: pointer;
		}
		.settings-category-btn:hover {
			background: #e9eff5;
		}
		.settings-category-btn.active {
			background: #334e68;
			border-color: #243b53;
			color: #ffffff;
		}
		.settings-form {
			display: grid;
			grid-template-columns: 1fr;
			gap: 10px;
		}
		.settings-field {
			border: 1px solid #bcc7d3;
			border-radius: 6px;
			padding: 10px;
			background: #fdfefe;
			overflow: hidden;
		}
		.settings-field label {
			display: block;
			font-size: 13px;
			font-weight: 600;
			color: #253443;
		}
		.settings-field small {
			display: block;
			margin-top: 4px;
			font-size: 11px;
			color: #4f6274;
			line-height: 1.35;
		}
		.settings-field .settings-source {
			margin-top: 6px;
			font-size: 10px;
			color: #66798a;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		.settings-field input[type="text"],
		.settings-field input[type="number"],
		.settings-field input[type="time"],
		.settings-field select {
			margin-top: 8px;
			width: 100%;
			max-width: 100%;
			min-width: 0;
			border: 1px solid #aebccb;
			border-radius: 6px;
			padding: 6px 8px;
			font-size: 13px;
			background: #ffffff;
			color: #22313f;
			display: block;
			box-sizing: border-box;
		}
		.settings-field input:focus,
		.settings-field select:focus {
			outline: none;
			border-color: #3b82c4;
			box-shadow: 0 0 0 2px rgba(59, 130, 196, 0.16);
