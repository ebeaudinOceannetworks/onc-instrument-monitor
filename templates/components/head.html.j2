			box-shadow: 0 8px 18px rgba(15, 23, 42, 0.14);
		}
		.public-section-sensor-line {
			display: grid;
			gap: 4px;
		}
		.internal-section-name-line {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
