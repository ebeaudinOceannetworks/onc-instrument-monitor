	function closeCacheModal() {
		var modal = document.getElementById('cache-modal');
		if (modal) modal.style.display = 'none';
	}

	function loadCacheConfig() {
		fetch(buildDashboardUrl('/api/verification/cache/config'))
			.then(function(resp) { return resp.json(); })
			.then(function(data) {
				if (!data || data.status !== 'ok') return;
				var cfg = data.config || {};
				document.getElementById('cache-shared-dir').value = cfg.shared_data_dir || '';
				document.getElementById('cache-local-dir').value = cfg.local_cache_dir || '';
				document.getElementById('cache-target-date').value = cfg.target_date || 'latest';
				document.getElementById('cache-global-threshold').value = cfg.global_threshold || 0.8;
				document.getElementById('cache-include-verified').checked = !!cfg.include_verified;
				document.getElementById('cache-include-audio').checked = cfg.include_audio !== false;
				document.getElementById('cache-transfer-method').value = cfg.transfer_method || 'copy';
				document.getElementById('cache-transfer-workers').value = cfg.transfer_workers || 4;
				var thresholds = cfg.class_thresholds || {};
				document.getElementById('cache-class-thresholds').value = JSON.stringify(thresholds, null, 2);
			})
			.catch(function() {});
	}

	function setAnalyzeLoading(isLoading, message) {
		var btn = document.getElementById('cache-analyze-btn');
		var summary = document.getElementById('cache-analysis-summary');
		if (btn) {
			btn.disabled = !!isLoading;
			btn.classList.toggle('loading', !!isLoading);
		}
		if (summary && message) summary.textContent = message;
	}

	function _parseThresholdsJson() {
		var raw = document.getElementById('cache-class-thresholds').value || '';
		if (!raw.trim()) return {};
		try {
			var parsed = JSON.parse(raw);
			if (typeof parsed !== 'object' || Array.isArray(parsed) || parsed === null) return {};
			return parsed;
		} catch (e) {
			alert('Per-class thresholds must be valid JSON.');
			return null;
		}
	}

	function _buildCachePayload(selection) {
		var thresholds = _parseThresholdsJson();
		if (thresholds === null) return null;
		var payload = {
			shared_data_dir: document.getElementById('cache-shared-dir').value,
			local_cache_dir: document.getElementById('cache-local-dir').value,
			target_date: document.getElementById('cache-target-date').value || 'latest',
			global_threshold: parseFloat(document.getElementById('cache-global-threshold').value || '0.8'),
			include_verified: document.getElementById('cache-include-verified').checked,
			include_audio: document.getElementById('cache-include-audio').checked,
			transfer_method: document.getElementById('cache-transfer-method').value,
			transfer_workers: parseInt(document.getElementById('cache-transfer-workers').value || '4', 10),
			class_thresholds: thresholds
		};
		if (selection) {
			if (selection.selected_devices) payload.selected_devices = selection.selected_devices;
			if (selection.selected_labels_by_device) payload.selected_labels_by_device = selection.selected_labels_by_device;
			if (selection.selected_labels) payload.selected_labels = selection.selected_labels;
		}
		return payload;
	}

	function analyzeCache(selection) {
		var copyBtn = document.getElementById('cache-copy-btn');
		if (copyBtn) copyBtn.disabled = true;
		var payload = _buildCachePayload(selection);
		if (!payload) {
			setAnalyzeLoading(false);
			return;
		}
		var dateHint = payload.target_date || 'latest';
		setAnalyzeLoading(true, 'Analyzing ' + dateHint + '…');
		fetch(buildDashboardUrl('/api/verification/cache/analyze'), {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(payload)
		})
			.then(function(resp) {
				if (!resp.ok) throw new Error('Analyze request failed');
				return resp.json();
			})
			.then(function(data) {
				setAnalyzeLoading(false);
				if (!data || data.status !== 'ok') {
					setAnalyzeLoading(false, data.message || 'Analysis failed.');
					return;
				}
				var preserve = selection !== undefined;
				renderCacheAnalysis(data, preserve);
			})
			.catch(function() {
				setAnalyzeLoading(false, 'Could not reach the dashboard server.');
			});
	}

	function renderCacheAnalysis(data, preserveSelection) {
		var summary = document.getElementById('cache-analysis-summary');
		var copyBtn = document.getElementById('cache-copy-btn');
		window.cacheAnalysisData = data || null;
		if (copyBtn) copyBtn.disabled = false;
		if (!preserveSelection) {
			renderCacheLabels(data.device_label_counts || {}, data.device_counts_threshold || {});
		}
		updateCacheSelectionSummary();
	}

	function computeSelectionSummary(data, selection) {
		var summary = {
			items_selected: 0,
			files_total: 0,
			file_counts: { audio: 0, spectrogram_mat: 0, spectrogram_image: 0, other: 0 },
			bytes_total: 0,
			bytes_by_type: { audio: 0, spectrogram_mat: 0, spectrogram_image: 0, other: 0 }
		};
		if (!data || !data.item_summaries) return summary;

		var includeVerified = document.getElementById('cache-include-verified').checked;
		var includeAudio = document.getElementById('cache-include-audio').checked;
		var samples = data.sample_sizes || {};
		var selectedDevices = (selection && selection.selected_devices) || [];
		var labelsByDevice = (selection && selection.selected_labels_by_device) || {};
		var hasSelection = selection && selection.any_checked;
		if (!hasSelection) return summary;

		var seenAll = new Set();
		var seenByType = {
			audio: new Set(),
			spectrogram_mat: new Set(),
			spectrogram_image: new Set(),
			other: new Set()
		};

		data.item_summaries.forEach(function(item) {
			var device = item.device || 'Unknown';
			if (hasSelection && selectedDevices.indexOf(device) === -1) return;

			var labels = item.labels || [];
			var verified = !!item.verified;
			var include = false;

			if (includeVerified && verified) {
				include = true;
			} else if (labels.length) {
				if (!hasSelection) {
					include = true;
				} else {
					var deviceLabels = labelsByDevice[device] || [];
					for (var i = 0; i < labels.length; i++) {
						if (deviceLabels.indexOf(labels[i]) !== -1) {
							include = true;
							break;
						}
					}
				}
			}

			if (!include) return;

			summary.items_selected += 1;
			if (item.file_keys && item.file_keys.length) {
				item.file_keys.forEach(function(entry) {
					var ftype = entry.type || 'other';
					if (!includeAudio && ftype === 'audio') return;
					var key = entry.key || '';
					var compound = ftype + '|' + key;
					if (!key) return;
					seenAll.add(compound);
					if (seenByType[ftype]) seenByType[ftype].add(compound);
				});
			} else {
				(item.file_types || []).forEach(function(ftype) {
					if (!includeAudio && ftype === 'audio') return;
					var compound = ftype + '|item:' + summary.items_selected;
					seenAll.add(compound);
					if (seenByType[ftype]) seenByType[ftype].add(compound);
				});
			}
		});

		Object.keys(seenByType).forEach(function(ftype) {
			var count = seenByType[ftype].size;
			summary.file_counts[ftype] = count;
			var bytes = (samples[ftype] || 0) * count;
			summary.bytes_by_type[ftype] = bytes;
			summary.bytes_total += bytes;
			summary.files_total += count;
		});

		return summary;
	}

	function updateCacheSelectionSummary() {
		var data = window.cacheAnalysisData;
		if (!data) return;
		var selection = getCacheSelection();
		var computed = computeSelectionSummary(data, selection);
		var summary = document.getElementById('cache-analysis-summary');
		var copyBtn = document.getElementById('cache-copy-btn');
		if (summary) {
			var size = formatBytes(computed.bytes_total || 0);
			var counts = computed.file_counts || {};
			var audioCount = counts.audio || 0;
			var matCount = counts.spectrogram_mat || 0;
			var imgCount = counts.spectrogram_image || 0;
			var otherCount = counts.other || 0;
			var audioSize = formatBytes((computed.bytes_by_type || {}).audio || 0);
			var sizeNote = data.size_estimated ? ' (estimated)' : '';
			var missingText = data.missing_files === null || data.missing_files === undefined
				? 'n/a'
				: data.missing_files;
			summary.innerHTML =
				'Date: ' + (data.date || 'latest') +
				' · Total items: ' + (data.total_items || 0) +
				' · Above threshold: ' + (data.items_above_threshold || 0) +
				' · Selected: ' + (computed.items_selected || 0) +
				'<br>Files: ' + (computed.files_total || 0) +
				' (audio: ' + audioCount + ', mat: ' + matCount + ', images: ' + imgCount + ', other: ' + otherCount + ')' +
				'<br>Size: ' + size + sizeNote + ' (audio: ' + audioSize + ')' +
				' · Missing: ' + missingText;
		}
		if (copyBtn) copyBtn.disabled = computed.items_selected === 0;
	}

	function updateDeviceCheckboxState(deviceCheckbox, labelContainer) {
		if (!deviceCheckbox || !labelContainer) return;
		var labelInputs = labelContainer.querySelectorAll('input[data-label]');
		var checked = 0;
		labelInputs.forEach(function(input) { if (input.checked) checked++; });
		deviceCheckbox.indeterminate = checked > 0 && checked < labelInputs.length;
		deviceCheckbox.checked = checked > 0 && checked === labelInputs.length;
	}

	function renderCacheLabels(deviceLabelCounts, deviceCounts) {
		var list = document.getElementById('cache-label-list');
		if (!list) return;
		list.innerHTML = '';
		var existing = getCacheSelection();
		var existingByDevice = existing.selected_labels_by_device || {};
		var devices = Object.keys(deviceLabelCounts || {}).sort(function(a, b) {
			return (deviceCounts[b] || 0) - (deviceCounts[a] || 0);
		});
		devices.forEach(function(device) {
			var labels = deviceLabelCounts[device] || {};
			var labelKeys = Object.keys(labels || {}).sort(function(a, b) {
				return (labels[b] || 0) - (labels[a] || 0);
			});
			if (!labelKeys.length) return;

			var group = document.createElement('div');
			group.className = 'cache-device-group';

			var header = document.createElement('div');
			header.className = 'cache-device-header';

			var deviceLabel = document.createElement('label');
			deviceLabel.className = 'cache-device-toggle';
			var deviceCheckbox = document.createElement('input');
			deviceCheckbox.type = 'checkbox';
			deviceCheckbox.className = 'cache-device-checkbox';
			deviceCheckbox.setAttribute('data-device', device);
			deviceLabel.appendChild(deviceCheckbox);
			var deviceName = document.createElement('span');
			deviceName.className = 'cache-device-name';
			deviceName.textContent = ' ' + device;
			deviceLabel.appendChild(deviceName);
			header.appendChild(deviceLabel);

			var deviceCount = document.createElement('span');
			deviceCount.className = 'cache-label-count';
			deviceCount.textContent = (deviceCounts && deviceCounts[device] !== undefined) ? deviceCounts[device] : '';
			header.appendChild(deviceCount);
			group.appendChild(header);

			var labelContainer = document.createElement('div');
			labelContainer.className = 'cache-device-labels';

			var existingLabels = existingByDevice[device] || [];
			var autoSelectAll = existingLabels.length === 0;

			labelKeys.forEach(function(label) {
				var row = document.createElement('div');
				row.className = 'cache-label-item cache-label-item--nested';
				var left = document.createElement('label');
				var checkbox = document.createElement('input');
				checkbox.type = 'checkbox';
				checkbox.setAttribute('data-device', device);
				checkbox.setAttribute('data-label', label);
				if (autoSelectAll || existingLabels.indexOf(label) !== -1) checkbox.checked = true;
				checkbox.addEventListener('change', function() {
					updateDeviceCheckboxState(deviceCheckbox, labelContainer);
					scheduleSelectionRecalc();
				});
				left.appendChild(checkbox);
				var name = document.createElement('span');
				name.className = 'cache-label-name';
				name.textContent = ' ' + label;
				left.appendChild(name);
				var count = document.createElement('span');
				count.className = 'cache-label-count';
				count.textContent = labels[label];
				row.appendChild(left);
				row.appendChild(count);
				labelContainer.appendChild(row);
			});

			group.appendChild(labelContainer);
			list.appendChild(group);

			updateDeviceCheckboxState(deviceCheckbox, labelContainer);
			deviceCheckbox.addEventListener('change', function() {
				var checked = deviceCheckbox.checked;
				var inputs = labelContainer.querySelectorAll('input[data-label]');
				inputs.forEach(function(input) { input.checked = checked; });
				updateDeviceCheckboxState(deviceCheckbox, labelContainer);
				scheduleSelectionRecalc();
			});
		});
	}

	function getCacheSelection() {
		var list = document.getElementById('cache-label-list');
		var selection = { selected_devices: [], selected_labels_by_device: {}, any_checked: false };
		if (!list) return selection;
		var inputs = list.querySelectorAll('input[data-label]');
		inputs.forEach(function(input) {
			if (!input.checked) return;
			selection.any_checked = true;
			var device = input.getAttribute('data-device') || 'Unknown';
			var label = input.getAttribute('data-label');
			if (!selection.selected_labels_by_device[device]) {
				selection.selected_labels_by_device[device] = [];
			}
			selection.selected_labels_by_device[device].push(label);
		});
		selection.selected_devices = Object.keys(selection.selected_labels_by_device);
		return selection;
	}

	function selectAllCacheLabels() {
		var list = document.getElementById('cache-label-list');
		if (!list) return;
		var inputs = list.querySelectorAll('input[data-label]');
		inputs.forEach(function(input) { input.checked = true; });
		var deviceInputs = list.querySelectorAll('input.cache-device-checkbox');
		deviceInputs.forEach(function(deviceCheckbox) {
			var container = deviceCheckbox.closest('.cache-device-group').querySelector('.cache-device-labels');
			updateDeviceCheckboxState(deviceCheckbox, container);
		});
		scheduleSelectionRecalc();
	}

	function selectNoCacheLabels() {
		var list = document.getElementById('cache-label-list');
		if (!list) return;
		var inputs = list.querySelectorAll('input[data-label]');
		inputs.forEach(function(input) { input.checked = false; });
		var deviceInputs = list.querySelectorAll('input.cache-device-checkbox');
		deviceInputs.forEach(function(deviceCheckbox) {
			var container = deviceCheckbox.closest('.cache-device-group').querySelector('.cache-device-labels');
			updateDeviceCheckboxState(deviceCheckbox, container);
		});
		scheduleSelectionRecalc();
	}

	function scheduleSelectionRecalc() {
		if (cacheAnalyzeTimer) clearTimeout(cacheAnalyzeTimer);
		cacheAnalyzeTimer = setTimeout(function() {
			updateCacheSelectionSummary();
		}, 150);
	}

	function formatBytes(bytes) {
		if (!bytes) return '0 B';
		var units = ['B', 'KB', 'MB', 'GB', 'TB'];
		var idx = Math.floor(Math.log(bytes) / Math.log(1024));
		return (bytes / Math.pow(1024, idx)).toFixed(1) + ' ' + units[idx];
	}

	function showCacheProgress(show) {
		var block = document.getElementById('cache-progress-block');
		if (block) block.style.display = show ? 'block' : 'none';
	}

	function updateCacheProgress(status) {
		var msg = document.getElementById('cache-modal-message');
		var bar = document.getElementById('cache-progress-bar');
		var text = document.getElementById('cache-progress-text');
		if (!msg || !bar || !text) return;
		var total = parseInt(status.total || status.total_files || status.files_total || 0, 10);
		var copied = parseInt(status.copied || status.files_copied || 0, 10);
		if (status.message) msg.textContent = status.message;
		if (total > 0) {
			var pct = Math.max(0, Math.min(100, Math.round((copied / total) * 100)));
			bar.style.width = pct + '%';
			text.textContent = copied + ' / ' + total + ' files';
		} else {
			bar.style.width = '0%';
			text.textContent = '0 / 0 files';
		}
	}

	function copySelectedCache() {
		var btn = document.getElementById('cache-copy-btn');
		if (!btn || btn.disabled) return;
		var payload = _buildCachePayload(getCacheSelection());
		if (!payload) return;
		showCacheProgress(true);
		updateCacheProgress({ message: 'Starting...', copied: 0, total: 0 });

		fetch(buildDashboardUrl('/api/verification/cache'), {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(payload)
		})
			.then(function(resp) { return resp.json(); })
			.then(function(data) {
				if (data.status === 'error') {
					showCacheProgress(false);
					alert(data.message || 'Cache build failed.');
					return;
				}
				pollLocalCacheStatus();
			})
			.catch(function() {
				showCacheProgress(false);
				alert('Could not reach the dashboard server.');
			});
	}

	function pollLocalCacheStatus() {
		var attempts = 0;
		var timer = setInterval(function() {
			fetch(buildDashboardUrl('/api/verification/cache/status'))
				.then(function(resp) { return resp.json(); })
				.then(function(status) {
					attempts++;
					if (!status || !status.state) return;
					if (status.state === 'running') {
						updateCacheProgress(status);
						return;
					}
						if (status.state === 'done') {
							clearInterval(timer);
							updateCacheProgress(status);
							showCacheProgress(false);
							closeCacheModal();
							launchVerificationApp(
								status.data_dir || status.local_cache_dir,
								document.getElementById('cache-action-btn')
							);
							return;
						}
					if (status.state === 'error') {
						clearInterval(timer);
						updateCacheProgress(status);
						showCacheProgress(false);
						alert(status.message || 'Cache build failed.');
						return;
					}
				})
				.catch(function() {
					attempts++;
					if (attempts > 10) {
						clearInterval(timer);
						showCacheProgress(false);
					}
				});
		}, 1500);
	}

	document.addEventListener("DOMContentLoaded", function() {
		applyDashboardTheme(ACTIVE_THEME, false);
		syncVerificationToolVisibility();
		if (!isPublicDetailPage()) {
			initLastUpdatedIndicator();
			loadDashboardSettings();
			startRuntimeStatusPolling();
		}
		{% if show_public_notifications|default(dashboard_variant == 'public', true) %}
		if (isPublicDashboardPage()) {
			initPublicNotifications();
		}
		{% endif %}
		document.addEventListener('click', function(event) {
			var menu = document.getElementById('actions-menu');
			var toggle = document.getElementById('actions-menu-toggle');
			if (!menu || !toggle) return;
			if (!menu.contains(event.target) && !toggle.contains(event.target)) {
				closeActionsMenu();
			}
		});
		document.addEventListener('keydown', function(event) {
			if (event.key === 'Escape') closeActionsMenu();
		});
		window.addEventListener('beforeunload', function() {
			if (runtimeStatusPollTimer) {
				clearInterval(runtimeStatusPollTimer);
				runtimeStatusPollTimer = null;
			}
			if (publicRefreshPollTimer) {
				clearInterval(publicRefreshPollTimer);
				publicRefreshPollTimer = null;
			}
			if (scheduledReloadTimer) {
				clearTimeout(scheduledReloadTimer);
				scheduledReloadTimer = null;
			}
		});
	});
	</script>
