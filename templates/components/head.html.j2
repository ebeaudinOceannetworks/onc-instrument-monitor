	function launchVerificationApp(dataDir, btnOverride) {
		if (!canUseVerificationTools()) return;
		var btn = btnOverride || document.getElementById('verification-action-btn');
		if (!btn || btn.classList.contains('launching')) return;
		closeActionsMenu();
		var originalText = btn.getAttribute('data-default-text') || btn.textContent;
		btn.setAttribute('data-default-text', originalText);
		btn.classList.add('launching');
		btn.textContent = '⏳ Launching...';

		var payload = dataDir ? JSON.stringify({ data_dir: dataDir }) : null;
		var headers = payload ? { 'Content-Type': 'application/json' } : {};

		fetch(buildDashboardUrl('/api/verification/launch'), {
			method: 'POST',
			headers: headers,
			body: payload
		})
			.then(function(resp) { return resp.json(); })
			.then(function(data) {
				btn.classList.remove('launching');
				btn.textContent = originalText;
				if (data.status === 'disabled') {
					alert('Verification app is disabled. Set ENABLE_VERIFICATION_APP=true in .env');
					return;
				}
				if (data.status === 'not_installed') {
					alert(data.message || 'Verification app not installed.');
					return;
				}
				// Give the Dash app a moment to boot if just started
				var delay = data.status === 'started' ? 2000 : 200;
				setTimeout(function() { window.open(data.url, '_blank'); }, delay);
			})
			.catch(function() {
				btn.classList.remove('launching');
				btn.textContent = originalText;
				alert('Could not reach the dashboard server.');
			});
	}

	var cacheAnalyzeTimer = null;

