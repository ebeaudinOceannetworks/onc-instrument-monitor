	}

	function _notificationTitle(count) {
		if (!count) return 'No active notifications';
		return count + ' notification' + (count !== 1 ? 's' : '');
	}

	function _setNotificationCount(count) {
		var els = _getNotificationsElements();
		if (!els.count || !els.title) return;
		els.count.textContent = String(count);
		els.count.classList.toggle('is-empty', count === 0);
		els.title.textContent = _notificationTitle(count);
