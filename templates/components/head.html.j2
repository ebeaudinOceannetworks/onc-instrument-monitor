			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
			color: var(--theme-text-soft);
		}
		.public-section-sensor-name {
			font-size: 1.15rem;
			font-weight: 600;
			line-height: 1.35;
			color: var(--theme-text);
		}
		.internal-section-name-primary {
			font-size: 1.1rem;
			font-weight: 600;
			line-height: 1.35;
			color: var(--theme-text);
		}
		.internal-section-name-divider {
			width: 18px;
			height: 1px;
			background: var(--theme-border-strong);
