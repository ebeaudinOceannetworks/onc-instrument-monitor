		/* Header action buttons */
		.top-bar-actions {
			margin-left: auto;
			display: flex;
			align-items: center;
			gap: 12px;
			flex-shrink: 0;
		}
		.top-bar-meta {
			display: flex;
			flex-direction: column;
			align-items: flex-end;
			gap: 6px;
			min-width: 0;
		}
		.top-bar-status-strip {
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			justify-content: flex-end;
			gap: 8px 10px;
			padding: 5px 12px;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.2);
			border: 1px solid rgba(255, 255, 255, 0.35);
			max-width: 100%;
		}
		.top-bar-status-item {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			min-width: 0;
			white-space: nowrap;
		}
		.top-bar-status-label {
			font-size: 10px;
			font-weight: 700;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			color: rgba(255, 255, 255, 0.66);
		}
		.top-bar-status-separator {
			width: 1px;
			height: 14px;
			background: rgba(255, 255, 255, 0.22);
			flex: 0 0 auto;
		}
		.auto-refresh-status,
		.last-updated-indicator {
			font-size: 11px;
			font-weight: 600;
			color: rgba(255, 255, 255, 0.94);
			white-space: nowrap;
		}
			.last-updated-indicator.updating {
				color: rgba(255, 244, 196, 0.98);
			}
			.refresh-progress-indicator {
				font-size: 11px;
				padding: 4px 8px;
				border-radius: 999px;
				white-space: nowrap;
				max-width: 520px;
				overflow: hidden;
				text-overflow: ellipsis;
				align-self: flex-end;
			}
			.refresh-progress-indicator.active {
				background: rgba(255, 193, 7, 0.28);
				border-color: rgba(255, 225, 133, 0.85);
			}
			.refresh-progress-indicator.error {
				background: rgba(220, 53, 69, 0.28);
				border-color: rgba(255, 187, 196, 0.85);
			}
		.actions-dropdown {
			position: relative;
		}
		.actions-btn {
			padding: 8px 16px;
			background-color: #e9ecef;
			color: #1f2a36;
			border: 1px solid #b8c2cc;
			border-radius: 6px;
			cursor: pointer;
			font-size: 13px;
			font-weight: 600;
		}
		.actions-btn:hover {
			background-color: #dfe5ea;
		}
		.actions-menu {
			position: absolute;
			right: 0;
			top: calc(100% + 6px);
			min-width: 240px;
			background: #ffffff;
			border: 1px solid #b7c1cb;
			border-radius: 8px;
			box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
			padding: 6px;
			z-index: 130;
		}
		.action-menu-item {
			display: block;
			width: 100%;
			text-align: left;
			border: 1px solid transparent;
			background: #ffffff;
			color: #1f2a36;
			padding: 8px 10px;
			border-radius: 6px;
			font-size: 13px;
			cursor: pointer;
		}
		.action-menu-item:hover {
			background: #edf3f8;
			border-color: #c6d3df;
		}
		.action-menu-item.refreshing {
			background: #fff3cd;
			border-color: #ffe08a;
			color: #6c4b00;
			cursor: default;
		}
		.action-menu-item.launching {
			background: #fff3cd;
			border-color: #ffe08a;
			color: #6c4b00;
			cursor: default;
		}
		.refresh-status-btn {
			display: inline-flex;
			align-items: center;
			gap: 8px;
		}
		.action-menu-item.refresh-status-btn {
			display: flex;
			align-items: center;
			justify-content: flex-start;
			gap: 8px;
		}
		.refresh-button-label {
			min-width: 0;
		}
		.refresh-button-caret {
			opacity: 0.78;
			font-size: 12px;
			flex: 0 0 auto;
		}
		.refresh-progress-circle {
			--refresh-progress: 0;
			width: 18px;
			height: 18px;
			flex: 0 0 18px;
			display: inline-block;
			overflow: visible;
		}
		.refresh-progress-track,
		.refresh-progress-fill {
			fill: none;
			stroke-width: 2.5;
		}
		.refresh-progress-track {
			stroke: currentColor;
			opacity: 0.18;
		}
		.refresh-progress-fill {
			stroke: currentColor;
			stroke-linecap: round;
			stroke-dasharray: 50.27;
			stroke-dashoffset: calc(50.27 - (50.27 * var(--refresh-progress) / 100));
			transform: rotate(-90deg);
			transform-origin: 50% 50%;
			transition: stroke-dashoffset 0.22s ease, opacity 0.2s ease;
			opacity: 0;
		}
		.refresh-status-btn[data-refresh-state="running"] .refresh-progress-fill,
		.refresh-status-btn[data-refresh-state="complete"] .refresh-progress-fill,
		.refresh-status-btn[data-refresh-state="error"] .refresh-progress-fill {
			opacity: 1;
		}
		.refresh-status-btn[data-refresh-state="complete"] .refresh-progress-fill {
			stroke: #3ad29f;
		}
		.refresh-status-btn[data-refresh-state="error"] .refresh-progress-fill {
			stroke: #ff8f99;
		}
		.actions-btn.refreshing {
			background: #7c5d00;
			border-color: #ffe08a;
			color: #fff4cf;
		}
		.settings-btn {
			padding: 8px 12px;
			background-color: #334e68;
