<div class="archive-map-container">
	<div class="archive-map-head">
		<h4>Data Archive Map — last {{ device.availability_days }} days</h4>
		<span class="availability-meta">
			formats: {{ device.extensions_list | join(', ') }}
		</span>
	</div>

	<div class="archive-map-timeline-grid">
		
		<div class="archive-map-timeline-row header-row">
			<div class="archive-map-label-cell"></div>
			<div class="archive-map-tracks-container header-grid">
				{% for hour in range(24) %}
				<div class="hour-tick-mark"><span>{{ "%02d:00" | format(hour) }}</span></div>
				{% endfor %}
			</div>
		</div>

		{% for day in device.archive_timeline %}
		<div class="archive-map-timeline-row">
			<div class="archive-map-label-cell">{{ day.label }}</div>
			
			<div class="archive-map-tracks-container">
				
				<div class="hour-grid-backdrop">
					{% for hour in range(24) %}
					<div class="grid-backdrop-column"></div>
					{% endfor %}
				</div>

				{% for ext in device.extensions_list %}
				{% set files = day.extensions[ext] %}
				<div class="extension-track track-color-{{ ext }}" data-extension="{{ ext }}">
					{% for file in files %}
					<div class="file-segment" 
						 style="left: {{ file.left }}%; width: {{ file.width }}%;"
						 title="File: {{ file.filename }} &#10;Time Range: {{ file.start_str }} - {{ file.end_str }} (UTC)">
					</div>
					{% endfor %}
				</div>
				{% endfor %}

			</div>
		</div>
		{% endfor %}

	</div>

	<div class="archive-map-legend">
		{% for ext in device.extensions_list %}
		<div class="legend-item">
			<span class="legend-swatch swatch-color-{{ ext }}"></span>
			<span class="legend-label">{{ ext }}</span>
		</div>
		{% endfor %}
	</div>
</div>